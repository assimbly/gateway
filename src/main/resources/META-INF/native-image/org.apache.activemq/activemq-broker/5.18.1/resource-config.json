{
    "resources": [
            {
                "glob": "\\\\QMETA-INF/services/org/apache/activemq/broker/broker\\\\E",
                "condition": {
                    "typeReachable": "org.apache.activemq.broker.BrokerFactory"
                }
            },
            {
                "glob": "\\\\QMETA-INF/services/org/apache/activemq/transport/vm\\\\E",
                "condition": {
                    "typeReachable": "org.apache.activemq.transport.TransportFactory"
                }
            }
        ]
}
