{
    "resources": [
            {
                "glob": "\\\\QMETA-INF/services/org.apache.activemq.artemis.spi.core.remoting.ssl.OpenSSLContextFactory\\\\E",
                "condition": {
                    "typeReachable": "org.apache.activemq.artemis.spi.core.remoting.ssl.OpenSSLContextFactoryProvider"
                }
            },
            {
                "glob": "\\\\QMETA-INF/services/org.apache.activemq.artemis.spi.core.remoting.ssl.SSLContextFactory\\\\E",
                "condition": {
                    "typeReachable": "org.apache.activemq.artemis.spi.core.remoting.ssl.SSLContextFactoryProvider"
                }
            },
            {
                "glob": "\\\\Qactivemq-version.properties\\\\E",
                "condition": {
                    "typeReachable": "org.apache.activemq.artemis.utils.VersionLoader"
                }
            }
        ],
    "bundles": [
        
    ]
}
