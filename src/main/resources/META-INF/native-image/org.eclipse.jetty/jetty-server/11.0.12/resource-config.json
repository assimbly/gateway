{
  "bundles": [
    {
      "name": "jakarta.servlet.LocalStrings",
      "locales": [
        "und"
      ]
    },
    {
      "name": "jakarta.servlet.http.LocalStrings",
      "locales": [
        "und"
      ]
    }
  ],
  "resources": [
      {
        "condition": {
          "typeReachable": "org.eclipse.jetty.server.handler.ResourceHandler"
        },
        "glob": "\\\\Qjetty-dir.css\\\\E"
      },
      {
        "condition": {
          "typeReachable": "org.eclipse.jetty.http.MimeTypes"
        },
        "glob": "\\\\Qorg/eclipse/jetty/http/encoding.properties\\\\E"
      },
      {
        "condition": {
          "typeReachable": "org.eclipse.jetty.http.MimeTypes"
        },
        "glob": "\\\\Qorg/eclipse/jetty/http/mime.properties\\\\E"
      },
      {
        "condition": {
          "typeReachable": "org.eclipse.jetty.util.Jetty"
        },
        "glob": "\\\\Qorg/eclipse/jetty/version/build.properties\\\\E"
      },
      {
        "condition": {
          "typeReachable": "org.eclipse.jetty.util.resource.Resource"
        },
        "glob": "\\\\Qorg/eclipse/jetty/webapp/webdefault.xml\\\\E"
      }
    ]
}
